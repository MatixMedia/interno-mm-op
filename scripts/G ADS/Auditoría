    + ' ORDER BY metrics.impressions DESC '
    + 'LIMIT 300';

  var rows = AdsApp.search(query);
  var data = [headers];

  while (rows.hasNext()) {
    var r    = rows.next();
    var cost = r.metrics.costMicros / 1e6;
    var roas = cost > 0 ? (r.metrics.conversionsValue / cost) : 0;
    var texto = (r.asset && r.asset.textAsset) ? r.asset.textAsset.text : '(imagen/video/URL)';

    data.push([
      r.campaign.name,
      r.assetGroup.name,
      r.assetGroup.status,
      texto,
      r.asset ? r.asset.type : '—',
      '—',
      fmt(r.metrics.impressions),
      fmt(r.metrics.clicks),
      r.metrics.conversions.toFixed(1),
      '$' + fmt(r.metrics.conversionsValue),
      roas.toFixed(2) + '×'
    ]);
  }

  sheet.getRange(3, 1, data.length, data[0].length).setValues(data);
  applyTableStyle(sheet, 3, data.length, headers.length);

  // Colorear según rendimiento del asset
  for (var i = 1; i < data.length; i++) {
    var perf = data[i][5];
    var color = '';
    if (perf === 'BEST')  color = '#D4EDDA';
    if (perf === 'GOOD')  color = '#EAF3DE';
    if (perf === 'LOW')   color = '#F8D7DA';
    if (perf === 'LEARNING') color = '#FFF3CD';
    if (color) sheet.getRange(i + 3, 6, 1, 1).setBackground(color);
  }

  autoResizeCols(sheet, headers.length);
  log('✔ Assets P-Max');
}


