/**
 * ============================================================
 *  CLIENTE — SCRIPT DE DIAGNÓSTICO COMPLETO · GOOGLE ADS
 *  Genera un Google Sheet con 10 pestañas de análisis
 *  
 *  INSTRUCCIONES:
 *  1. Ve a Google Ads → Herramientas → Scripts
 *  2. Crea un nuevo script y pega este código completo
 *  3. Cambia SPREADSHEET_URL por la URL de un Google Sheet
 *     en blanco que hayas creado (o déjalo vacío para crear uno nuevo)
 *  4. Ajusta DATE_RANGE si quieres otro período
 *  5. Haz clic en "Ejecutar" (autoriza los permisos la primera vez)
 *  6. El Sheet se llenará automáticamente en ~1–2 minutos
 * ============================================================
 */

// ── CONFIGURACIÓN ──────────────────────────────────────────
var SPREADSHEET_URL = 'Pega la URL DRIVE del documento donde quedará el Informe';   // Déjalo vacío para crear uno nuevo automáticamente

// Opciones válidas: 'LAST_7_DAYS' | 'LAST_14_DAYS' | 'LAST_30_DAYS' | 'LAST_MONTH' | 'LAST_90_DAYS'
// LAST_90_DAYS se convierte automáticamente a rango de fechas exacto
var DATE_RANGE      = 'LAST_90_DAYS';
var ACCOUNT_NAME    = 'CLIENTE - ID DE CUENTA';
// ───────────────────────────────────────────────────────────

// Convierte DATE_RANGE a la cláusula WHERE correcta para GAQL
function buildDateClause(range) {
  // GAQL solo acepta estos rangos con DURING:
  var validDuring = ['TODAY','YESTERDAY','LAST_7_DAYS','LAST_14_DAYS',
                     'LAST_30_DAYS','LAST_BUSINESS_WEEK','THIS_MONTH',
                     'LAST_MONTH','THIS_WEEK_SUN_TODAY','THIS_WEEK_MON_TODAY',
                     'LAST_WEEK_SUN_SAT','LAST_WEEK_MON_SUN'];

  if (validDuring.indexOf(range) !== -1) {
    return 'WHERE segments.date DURING ' + range;
  }

  // Para rangos personalizados (ej. LAST_90_DAYS) usar fechas explícitas
  var today = new Date();
  var days  = parseInt(range.replace('LAST_', '').replace('_DAYS', ''), 10) || 30;
  var from  = new Date(today.getTime() - days * 24 * 60 * 60 * 1000);
  var fmt   = function(d) { return Utilities.formatDate(d, AdsApp.currentAccount().getTimeZone(), 'yyyy-MM-dd'); };
  return "WHERE segments.date BETWEEN '" + fmt(from) + "' AND '" + fmt(today) + "'";
}

function main() {
  var ss = getOrCreateSpreadsheet();
  var dateLabel = getDateLabel(DATE_RANGE);
  // Variable global usada por todas las pestañas
  DATE_CLAUSE = buildDateClause(DATE_RANGE);

  log('Iniciando extracción · ' + dateLabel);

  tab_Resumen(ss, dateLabel);
  tab_Campanas(ss, dateLabel);
  tab_GruposAnuncios(ss, dateLabel);
  tab_Keywords(ss, dateLabel);
  tab_TerminosBusqueda(ss, dateLabel);
  tab_Anuncios(ss, dateLabel);
  tab_AssetsPerformance(ss, dateLabel);
  tab_Geografico(ss, dateLabel);
  tab_Dispositivos(ss, dateLabel);
  tab_DiaSemana(ss, dateLabel);

  // Eliminar hoja por defecto si quedó vacía
  try {
    var defSheet = ss.getSheetByName('Sheet1') || ss.getSheetByName('Hoja1') || ss.getSheetByName('Hoja 1');
    if (defSheet && ss.getSheets().length > 1) ss.deleteSheet(defSheet);
  } catch(e) {}

  log('✅ Completado. Spreadsheet: ' + ss.getUrl());
  Logger.log('URL del informe: ' + ss.getUrl());
}


// ══════════════════════════════════════════════════════════════
// PESTAÑA 1 · RESUMEN EJECUTIVO
// ══════════════════════════════════════════════════════════════
function tab_Resumen(ss, dateLabel) {
  var sheet = getOrCreateSheet(ss, '1. Resumen');
  sheet.clear();
  styleHeader(sheet, '1 · RESUMEN EJECUTIVO — ' + ACCOUNT_NAME, dateLabel);

  var query = 'SELECT '
    + 'metrics.impressions, '
    + 'metrics.clicks, '
    + 'metrics.ctr, '
    + 'metrics.average_cpc, '
    + 'metrics.cost_micros, '
    + 'metrics.conversions, '
    + 'metrics.conversions_value, '
    + 'metrics.cost_per_conversion '
    + 'FROM customer '
    + DATE_CLAUSE;

  var rows = AdsApp.search(query);
  var data = [['Métrica', 'Valor', 'Referencia ideal']];

  while (rows.hasNext()) {
    var r = rows.next();
    var cost    = r.metrics.costMicros / 1e6;
    var convVal = r.metrics.conversionsValue;
    var convs   = r.metrics.conversions;
    var roas    = cost > 0 ? (convVal / cost) : 0;
    var cvr     = r.metrics.ctr > 0 ? (convs / r.metrics.clicks) * 100 : 0;

    data.push(['Impresiones',           fmt(r.metrics.impressions),           '—']);
    data.push(['Clics',                 fmt(r.metrics.clicks),                '—']);
    data.push(['CTR',                   pct(r.metrics.ctr),                   '> 3% Search / > 1% Display']);
    data.push(['CPC promedio (COP)',     '$' + fmt(r.metrics.averageCpc / 1e6), '—']);
    data.push(['Inversión total (COP)',  '$' + fmt(cost),                      '—']);
    data.push(['Conversiones',          fmt(convs),                           '—']);
    data.push(['Valor conversiones (COP)', '$' + fmt(convVal),                '—']);
    data.push(['ROAS',                  roas.toFixed(2) + '×',               '> 3× mínimo / > 5× óptimo']);
    data.push(['CVR (tasa conversión)',  cvr.toFixed(2) + '%',               '> 2% e-commerce']);
    data.push(['Costo / conversión (COP)', '$' + fmt(r.metrics.costPerConversion / 1e6), '< ticket promedio × margen']);
  }

  sheet.getRange(3, 1, data.length, data[0].length).setValues(data);
  applyTableStyle(sheet, 3, data.length, 3);
  sheet.setColumnWidth(1, 260);
  sheet.setColumnWidth(2, 180);
  sheet.setColumnWidth(3, 240);
  log('✔ Resumen');
}


