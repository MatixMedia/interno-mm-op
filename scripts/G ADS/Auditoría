    + 'segments.geo_target_city, '
    + 'segments.geo_target_region, '
    + 'metrics.impressions, '
    + 'metrics.clicks, '
    + 'metrics.ctr, '
    + 'metrics.average_cpc, '
    + 'metrics.cost_micros, '
    + 'metrics.conversions, '
    + 'metrics.conversions_value '
    + 'FROM geographic_view '
    + DATE_CLAUSE
    + ' ORDER BY metrics.cost_micros DESC '
    + 'LIMIT 200';

  var rows = AdsApp.search(query);
  var data = [headers];

  while (rows.hasNext()) {
    var r    = rows.next();
    var cost = r.metrics.costMicros / 1e6;
    var convVal = r.metrics.conversionsValue;
    var convs   = r.metrics.conversions;
    var clicks  = r.metrics.clicks;
    var roas    = cost > 0 ? (convVal / cost) : 0;
    var cvr     = clicks > 0 ? (convs / clicks * 100) : 0;
    var ciudad  = (r.segments && r.segments.geoTargetCity) ? r.segments.geoTargetCity : '—';
    var region  = (r.segments && r.segments.geoTargetRegion) ? r.segments.geoTargetRegion : '—';

    data.push([
      ciudad, region,
      r.campaign.name,
      fmt(r.metrics.impressions),
      fmt(clicks),
      pct(r.metrics.ctr),
      '$' + fmt(r.metrics.averageCpc / 1e6),
      '$' + fmt(cost),
      convs.toFixed(1),
      '$' + fmt(convVal),
      roas.toFixed(2) + '×',
      cvr.toFixed(2) + '%'
    ]);
  }

  sheet.getRange(3, 1, data.length, data[0].length).setValues(data);
  applyTableStyle(sheet, 3, data.length, headers.length);
  autoResizeCols(sheet, headers.length);
  log('✔ Geografía');
}


