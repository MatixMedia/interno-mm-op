// ══════════════════════════════════════════════════════════════
// UTILIDADES
// ══════════════════════════════════════════════════════════════

function getOrCreateSpreadsheet() {
  if (SPREADSHEET_URL && SPREADSHEET_URL.length > 10) {
    return SpreadsheetApp.openByUrl(SPREADSHEET_URL);
  }
  var ss = SpreadsheetApp.create('HUA · Diagnóstico Google Ads · ' + Utilities.formatDate(new Date(), 'America/Bogota', 'dd-MM-yyyy'));
  Logger.log('Nuevo spreadsheet creado: ' + ss.getUrl());
  return ss;
}

function getOrCreateSheet(ss, name) {
  var sheet = ss.getSheetByName(name);
  if (!sheet) sheet = ss.insertSheet(name);
  return sheet;
}

function styleHeader(sheet, title, subtitle) {
  sheet.getRange(1, 1).setValue(title)
    .setFontSize(13).setFontWeight('bold').setFontColor('#1a1a1a');
  sheet.getRange(2, 1).setValue(subtitle + '  |  Generado: ' + Utilities.formatDate(new Date(), 'America/Bogota', 'dd/MM/yyyy HH:mm'))
    .setFontSize(10).setFontColor('#666666').setFontStyle('italic');
}

function applyTableStyle(sheet, startRow, numRows, numCols) {
  if (numRows < 1) return;
  // Header row
  var headerRange = sheet.getRange(startRow, 1, 1, numCols);
  headerRange.setBackground('#1a3a5c').setFontColor('#FFFFFF')
             .setFontWeight('bold').setFontSize(10);
  // Alternating rows
  for (var i = 1; i < numRows; i++) {
    var bg = i % 2 === 0 ? '#F8F9FA' : '#FFFFFF';
    sheet.getRange(startRow + i, 1, 1, numCols).setBackground(bg);
  }
  // Borders
  sheet.getRange(startRow, 1, numRows, numCols)
       .setBorder(true, true, true, true, true, true, '#DDDDDD',
                  SpreadsheetApp.BorderStyle.SOLID_MEDIUM);
  sheet.setFrozenRows(startRow);
}

function autoResizeCols(sheet, numCols) {
  for (var i = 1; i <= numCols; i++) {
    sheet.autoResizeColumn(i);
    var w = sheet.getColumnWidth(i);
    if (w > 280) sheet.setColumnWidth(i, 280);
    if (w < 80)  sheet.setColumnWidth(i, 80);
  }
}

function fmt(n) {
  if (n === null || n === undefined || isNaN(n)) return '0';
  return Math.round(n).toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.');
}

function pct(n) {
  if (!n) return '0.00%';
  return (n * 100).toFixed(2) + '%';
}

function getDateLabel(range) {
  var labels = {
    'LAST_7_DAYS':  'Últimos 7 días',
    'LAST_30_DAYS': 'Últimos 30 días',
    'LAST_90_DAYS': 'Últimos 90 días'
  };
  return labels[range] || range;
}

function log(msg) {
  Logger.log('[diag_MM Script] ' + msg);
}
