  var headers = ['Campaña','Asset group','Estado','Título del asset','Tipo',
    'Rendimiento','Impres.','Clics','Conv.','Valor conv (COP)','ROAS'];

  var query = 'SELECT '
    + 'campaign.name, '
    + 'asset_group.name, '
    + 'asset_group.status, '
    + 'asset_group_asset.field_type, '
    + 'asset.text_asset.text, '
    + 'asset.type, '
    + 'metrics.impressions, '
    + 'metrics.clicks, '
    + 'metrics.conversions, '
    + 'metrics.conversions_value, '
    + 'metrics.cost_micros '
