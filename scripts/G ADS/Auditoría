  styleHeader(sheet, '6 · ANUNCIOS (copies y rendimiento)', dateLabel);

  var headers = ['Campaña','Grupo','Tipo anuncio','Titular 1','Titular 2','Titular 3',
    'Descripción 1','URL final','Estado',
    'Impres.','Clics','CTR','Conv.','Valor conv (COP)','ROAS','CVR','Calidad'];

  var query = 'SELECT '
    + 'campaign.name, '
    + 'ad_group.name, '
    + 'ad_group_ad.ad.type, '
    + 'ad_group_ad.ad.responsive_search_ad.headlines, '
    + 'ad_group_ad.ad.responsive_search_ad.descriptions, '
    + 'ad_group_ad.ad.final_urls, '
    + 'ad_group_ad.status, '
    + 'ad_group_ad.ad_strength, '
    + 'metrics.impressions, '
    + 'metrics.clicks, '
    + 'metrics.ctr, '
    + 'metrics.conversions, '
    + 'metrics.conversions_value, '
    + 'metrics.cost_micros '
    + 'FROM ad_group_ad '
    + DATE_CLAUSE
    + ' AND ad_group_ad.status != "REMOVED" '
    + 'ORDER BY metrics.impressions DESC '
    + 'LIMIT 200';

  var rows = AdsApp.search(query);
  var data = [headers];

  while (rows.hasNext()) {
    var r    = rows.next();
    var ad   = r.adGroupAd.ad;
    var cost = r.metrics.costMicros / 1e6;
    var convVal = r.metrics.conversionsValue;
    var convs   = r.metrics.conversions;
    var clicks  = r.metrics.clicks;
    var roas    = cost > 0 ? (convVal / cost) : 0;
    var cvr     = clicks > 0 ? (convs / clicks * 100) : 0;

    // Extraer headlines y descripciones de RSA
    var h1 = '—', h2 = '—', h3 = '—', d1 = '—';
    if (ad.responsiveSearchAd) {
      var headlines = ad.responsiveSearchAd.headlines || [];
      var descs     = ad.responsiveSearchAd.descriptions || [];
      h1 = headlines[0] ? headlines[0].text : '—';
      h2 = headlines[1] ? headlines[1].text : '—';
      h3 = headlines[2] ? headlines[2].text : '—';
      d1 = descs[0] ? descs[0].text : '—';
    }

    var finalUrl = (ad.finalUrls && ad.finalUrls[0]) ? ad.finalUrls[0] : '—';

    data.push([
      r.campaign.name,
      r.adGroup.name,
      ad.type,
      h1, h2, h3, d1,
      finalUrl,
      r.adGroupAd.status,
      fmt(r.metrics.impressions),
      fmt(clicks),
      pct(r.metrics.ctr),
      convs.toFixed(1),
      '$' + fmt(convVal),
      roas.toFixed(2) + '×',
      cvr.toFixed(2) + '%',
      r.adGroupAd.adStrength || '—'
    ]);
  }

  sheet.getRange(3, 1, data.length, data[0].length).setValues(data);
  applyTableStyle(sheet, 3, data.length, headers.length);
  autoResizeCols(sheet, headers.length);
  log('✔ Anuncios');
