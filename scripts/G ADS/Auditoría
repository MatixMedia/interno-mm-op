  highlightWasteTerms(sheet, data);
  log('✔ Términos de búsqueda');
}

function highlightWasteTerms(sheet, data) {
  // Resaltar en amarillo filas con > $5.000 COP gasto y 0 conversiones
  for (var i = 1; i < data.length; i++) {
    var row   = data[i];
    var gasto = parseFloat(String(row[9]).replace(/[$,.]/g, '')) || 0;
    var convs = parseFloat(row[10]) || 0;
    if (gasto > 5000 && convs === 0) {
      sheet.getRange(i + 3, 1, 1, row.length)
           .setBackground('#FFF3CD');
    }
  }
}


